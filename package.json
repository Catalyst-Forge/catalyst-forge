{
  "name": "catalyst-forge",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:hris": "turbo run dev --filter=hris",
    "dev:crm": "turbo run dev --filter=crm",
    "dev:pos": "turbo run dev --filter=pos",
    "dev:ai-support": "turbo run dev --filter=ai-support",
    "dev:company": "turbo run dev --filter=company",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
